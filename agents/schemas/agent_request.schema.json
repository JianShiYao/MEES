{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mees.local/schemas/agent_request.schema.json",
  "title": "MEES Agent Request",
  "type": "object",
  "required": ["run_id", "agent", "task", "inputs"],
  "additionalProperties": false,
  "properties": {
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "agent": {"type": "string", "enum": ["requirement", "architecture", "review", "test", "aspice", "metrics"]},
    "task": {"type": "string", "minLength": 1},
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "evidence_state"],
        "additionalProperties": false,
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "evidence_state": {"type": "string", "enum": ["D", "S"]}
        }
      }
    }
  }
}
